{
  "name": "ai-ecommerce-ops-platform",
  "private": true,
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "dev": "pnpm --filter @shkf/web dev",
    "build": "pnpm --filter @shkf/web build",
    "start": "pnpm --filter @shkf/web start",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @shkf/db db:generate",
    "db:validate": "pnpm --filter @shkf/db db:validate",
    "verify": "pnpm db:generate && pnpm db:validate && pnpm typecheck && pnpm build"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "typescript": "6.0.3"
  }
}
