APP_BASE_URL=http://127.0.0.1:4173

# Repository（数据访问层）模式：
# demo = 默认演示数据，不连接真实数据库。
# postgres = 本地 PostgreSQL（数据库）只读路径；必须同时打开 ENABLE_POSTGRES_SUPPORT_REPOSITORY。
SUPPORT_REPOSITORY_MODE=demo
# false = 默认关闭数据库路径，保护 Demo。
# true = 仅允许本地 PostgreSQL 只读查询，不能写入真实客户消息。
ENABLE_POSTGRES_SUPPORT_REPOSITORY=false

# 本地开发数据库示例，不是真实生产密码。
# 生产环境必须换成正式数据库地址，并且只能放在 .env.local 或部署平台环境变量里，不能提交到 Git。
DATABASE_URL=postgres://atomi:atomi@127.0.0.1:55432/atomi_growth
REDIS_URL=redis://127.0.0.1:6379

# 加密密钥示例。生产环境必须使用随机生成的 32 字节 base64 密钥，不能使用这个占位值。
SECRETS_ENCRYPTION_KEY=replace-with-32-byte-base64-key
S3_BUCKET=atomi-shine-growth-assets
S3_CLOUDFRONT_URL=https://cdn.example.com

# 可选平台凭证。只能放服务端环境变量，不要写进前端页面，不要提交真实值。
META_APP_ID=
META_APP_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
SHOPIFY_APP_CLIENT_ID=
SHOPIFY_APP_CLIENT_SECRET=
